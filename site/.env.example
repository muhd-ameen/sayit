# Sample env for the SayIt refine proxy.
# Copy to `site/.env` (gitignored) for local `netlify dev`,
# and set the same values in the Netlify dashboard for production.

# Your real Anthropic API key. Server-side only — never ships in the app.
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Shared token the macOS app sends in the `x-sayit-app` header.
# Generate one with:  openssl rand -hex 24
# Use the SAME value when building the app:  SAYIT_APP_TOKEN=... make app
SAYIT_APP_TOKEN=sayit_replace_with_a_random_string
